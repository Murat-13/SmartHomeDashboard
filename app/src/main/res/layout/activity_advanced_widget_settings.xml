<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2A2A2A"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="Расширенные настройки"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Размер шрифта -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Размер шрифта (sp)"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etFontSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2A2A2A"
                android:textColor="#FFFFFF"
                android:padding="12dp"
                android:inputType="number"
                android:text="16" />

            <!-- Датчики в свёрнутом виде -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Датчики в свёрнутом виде"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvCollapsedHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Нажмите, чтобы выбрать"
                android:textColor="#888888"
                android:textSize="14sp"
                android:padding="12dp"
                android:background="#2A2A2A" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCollapsedSensors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Датчики в развёрнутом виде -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Датчики в развёрнутом виде"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvExpandedHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Нажмите, чтобы выбрать"
                android:textColor="#888888"
                android:textSize="14sp"
                android:padding="12dp"
                android:background="#2A2A2A" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvExpandedSensors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Условия смены цвета -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Условия смены цвета"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnAddColorRule"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="+ Добавить условие"
                android:backgroundTint="#424242" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvColorRules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <!-- Источник данных -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Источник данных"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerDataSource"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#2A2A2A"
                android:entries="@array/data_source_options" />

            <!-- Кнопки -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp">

                <Button
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Отмена"
                    android:backgroundTint="#555555" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Сохранить"
                    android:backgroundTint="#4CAF50" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>