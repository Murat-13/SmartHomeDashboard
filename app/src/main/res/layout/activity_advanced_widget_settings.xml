<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2A2A2A"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/advanced_settings"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Выбор иконки -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_icon"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivSelectedIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="#2A2A2A"
                    android:padding="8dp"
                    android:src="@drawable/ic_widgets"
                    android:contentDescription="@string/widget_icon"
                    app:tint="#FFFFFF" />

                <Button
                    android:id="@+id/btnSelectIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    android:text="@string/select_icon"
                    android:backgroundTint="#424242" />

                <Button
                    android:id="@+id/btnUploadIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/upload"
                    android:backgroundTint="#424242" />

            </LinearLayout>

            <!-- Размер шрифта -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/font_size_sp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnFontSizeMinus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="@string/minus"
                    android:textSize="24sp"
                    android:backgroundTint="#424242" />

                <TextView
                    android:id="@+id/tvFontSize"
                    android:layout_width="80dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="@string/default_font_size"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:background="#2A2A2A" />

                <Button
                    android:id="@+id/btnFontSizePlus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="@string/plus"
                    android:textSize="24sp"
                    android:backgroundTint="#424242" />

            </LinearLayout>

            <!-- Датчики в свёрнутом виде -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/collapsed_sensors"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvCollapsedHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tap_to_select"
                android:textColor="#888888"
                android:textSize="14sp"
                android:padding="12dp"
                android:background="#2A2A2A" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCollapsedSensors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Датчики в развёрнутом виде -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/expanded_sensors"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvExpandedHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tap_to_select"
                android:textColor="#888888"
                android:textSize="14sp"
                android:padding="12dp"
                android:background="#2A2A2A" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvExpandedSensors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Условия смены цвета -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/color_conditions"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnAddColorRule"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/add_condition"
                android:backgroundTint="#424242" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvColorRules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <!-- Источник данных -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/data_source"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerDataSource"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#2A2A2A"
                android:entries="@array/data_source_options" />

            <!-- Кнопки -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                style="?android:attr/buttonBarStyle"
                android:layout_marginTop="32dp">

                <Button
                    android:id="@+id/btnCancel"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/cancel"
                    android:backgroundTint="#555555" />

                <Button
                    android:id="@+id/btnSave"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/save"
                    android:backgroundTint="#4CAF50" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>