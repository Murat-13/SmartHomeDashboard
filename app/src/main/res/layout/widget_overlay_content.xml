<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/overlayTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Title"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/overlayVoltage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 V"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/overlayCurrent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current: 0 A"
        android:textColor="#CCCCCC"
        android:textSize="18sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/overlayPower"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Power: 0 W"
        android:textColor="#CCCCCC"
        android:textSize="18sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/overlayFrequency"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Frequency: 0 Hz"
        android:textColor="#CCCCCC"
        android:textSize="18sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/overlayEnergy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Energy: 0 kWh"
        android:textColor="#CCCCCC"
        android:textSize="18sp" />

</LinearLayout>