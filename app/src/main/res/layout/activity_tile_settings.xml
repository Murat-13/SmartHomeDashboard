<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2A2A2A"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/tile_settings_title"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tile_title_label"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etTileTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2A2A2A"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:padding="12dp"
                android:hint="@string/tile_title_hint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tile_type_label"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerTileType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#2A2A2A"
                android:entries="@array/tile_types" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sensors_label"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnSelectSensors"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/select_sensors"
                android:backgroundTint="#424242" />

            <TextView
                android:id="@+id/tvSelectedSensors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/none_selected"
                android:textColor="#888888"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnEditChildren"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Редактировать группу"
                android:backgroundTint="#FF9800"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnAdvanced"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Расширенные настройки"
                android:backgroundTint="#424242" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/save"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="@string/delete"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF5555"
                android:textSize="16sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>